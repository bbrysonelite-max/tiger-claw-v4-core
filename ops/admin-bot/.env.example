# Tiger Claw Admin Bot — Environment Variables

# Telegram bot for Brent's admin channel
ADMIN_TELEGRAM_BOT_TOKEN=<your-admin-bot-token>
ADMIN_TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# Tiger Claw API
TIGER_CLAW_API_URL=http://localhost:4000
ADMIN_TOKEN=<same-as-api-admin-token>

# Path to deploy state file written by ops/deploy.sh
DEPLOY_STATE_PATH=/home/ubuntu/tiger-claw/deployment_state.json
