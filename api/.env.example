# Tiger Claw API — Environment Variables
# Copy to .env and fill in all values before deploying
# Run: cp .env.example .env

# PostgreSQL (Cloud SQL — get connection string after terraform apply)
DATABASE_URL=postgresql://botcraft:CHANGE_ME@CLOUD_SQL_IP:5432/tiger_bot

# Redis (Memorystore — get host after terraform apply)
REDIS_URL=redis://MEMORYSTORE_IP:6379

# Google API (Gemini — platform keys, used for 4-layer key system)
# IMPORTANT: These are Google API keys (AIza...), NOT Anthropic keys
GOOGLE_API_KEY=AIza...
PLATFORM_ONBOARDING_KEY=AIza...
PLATFORM_EMERGENCY_KEY=AIza...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MANAGED=price_...
STRIPE_PRICE_BYOK=price_...

# Admin protection (generate a strong random secret)
ADMIN_TOKEN=CHANGE_ME_STRONG_SECRET

# Admin Telegram alerts (operator's personal bot for fleet alerts)
ADMIN_TELEGRAM_BOT_TOKEN=<your-admin-bot-token>
ADMIN_TELEGRAM_CHAT_ID=<your-chat-id>

# Hive shared secret (between API and all tenant agents)
TIGER_CLAW_HIVE_TOKEN=CHANGE_ME_STRONG_SECRET

# Encryption key for bot tokens and API keys (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-hex_32

# Serper search API keys (web search for tiger_scout)
SERPER_KEY_1=
SERPER_KEY_2=
SERPER_KEY_3=

# Frontend URL (for Stripe redirect after payment)
FRONTEND_URL=https://app.tigerclaw.io

# Public API URL (external — used by provisioner to register Telegram webhooks)
TIGER_CLAW_API_URL=https://api.tigerclaw.io

# Internal API URL (used by tools for self-calls within the same process/cluster)
# K8s: http://tiger-claw-api:4000  |  Local dev: http://localhost:4000
INTERNAL_API_URL=http://tiger-claw-api:4000

# GCP project ID (used by deploy scripts and cloudrun.yaml substitution)
GCP_PROJECT_ID=CHANGE_ME

# Port
PORT=4000
NODE_ENV=production

RESEND_API_KEY=re_12345
